# LibreChat — point OpenAI-compatible traffic at LiteLLM on Railway.
# Copy into Railway variables or .env (do not commit secrets).
# Variable names follow upstream LibreChat; confirm against your deployed version:
# https://github.com/danny-avila/LibreChat

# LiteLLM exposes an OpenAI-compatible API at your Railway URL.
OPENAI_API_KEY=
# Use your LITELLM_MASTER_KEY or a virtual key from the LiteLLM admin UI.

# Base URL for the LiteLLM service (no trailing slash; LibreChat may append /v1).
OPENAI_API_BASE=
# Example: https://litellm-proxy-xxxx.up.railway.app/v1

# If your LibreChat version uses a different key for custom OpenAI base URL, set per upstream docs
# (e.g. some deployments use OPENAI_REVERSE_PROXY or endpoint-specific blocks in librechat.yaml).
