# Railway (or other host) — copy into project secrets / variables. Do not commit real values.
# After `terraform apply` in iac/, use outputs litellm_config_bucket_name and create an IAM access key for your LiteLLM user.

# S3 config location (LiteLLM loads config.yaml from this bucket; scripts/push-config.sh uses these for uploads)
LITELLM_CONFIG_BUCKET_NAME=
LITELLM_CONFIG_BUCKET_OBJECT_KEY=config.yaml

# Public proxy URL (push-config.sh polls RAILWAY_LITELLM_URL/health/liveliness after restart; override with LITELLM_HEALTH_URL)
RAILWAY_LITELLM_URL=
# LITELLM_HEALTH_URL=

# AWS credentials — IAM user with Bedrock invoke + S3 config policy (from iac/)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION_NAME=us-east-1

# Bind address for the proxy (LiteLLM / Uvicorn). Railway templates sometimes set HOST=:: (IPv6-only);
# the public URL then returns 502 because the edge connects over IPv4. Use 0.0.0.0.
PORT=4000
HOST=0.0.0.0

# LiteLLM admin / DB (Railway Postgres + Redis from template often wire DATABASE_URL / REDIS_URL automatically)
LITELLM_MASTER_KEY=sk-generate-a-strong-secret
LITELLM_SALT_KEY=sk-generate-a-different-secret
DATABASE_URL=
REDIS_URL=

# Optional: LiteLLM UI (when using template defaults)
UI_USERNAME=admin
UI_PASSWORD=
