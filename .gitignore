.terraform/
iac/.terraform/
*.tfplan*
**/tfplan.bin

# Railway / local env (apps) — ignore secrets, keep *.example committed
apps/**/.env
!apps/**/*.example

*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
# Env tfvars are the source of truth (incl. Cursor external ID); keep repo access private.
!environments/dev/terraform.tfvars
!environments/prod/terraform.tfvars
# Local Bedrock audit exports (may contain full prompts)
bedrock-audit*.txt

crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc
